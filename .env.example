# App
APP_ENV=development
API_PORT=8000
WEB_PORT=5173
DATABASE_URL=postgresql+psycopg://agent:agent@db:5432/agent_loop_dashboard

# Self-hosted Jira
JIRA_BASE_URL=https://jira.example.internal
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=

# GitLab
GITLAB_BASE_URL=https://gitlab.example.internal
GITLAB_TOKEN=
GITLAB_PROJECT_IDS=

# Anthropic Agent SDK endpoint
ANTHROPIC_BASE_URL=http://host.docker.internal:9000
ANTHROPIC_AUTH_TOKEN=
# Comma-separated label=model pairs. The first label is the default for new loops.
ANTHROPIC_MODEL_LABELS=fast=claude-3-5-haiku-latest,smart=claude-3-5-sonnet-latest
